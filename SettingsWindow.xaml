<Window x:Class="LujuPet.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="寵物設定" Height="580" Width="350"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 寵物大小 -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,5">
                <Label Content="寵物大小 (0.1 ~ 1.0)" Width="150"/>
                <TextBox x:Name="SizeBox" Text="{Binding PetSize}" Width="100" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- 兩欄 CheckBox -->
            <Grid Grid.Row="1" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <CheckBox x:Name="WorkBox" IsChecked="{Binding AllowWork}" Content="允許工作" Margin="0,5"/>
                    <CheckBox x:Name="WalkBox" IsChecked="{Binding AllowWalk}" Content="允許走動" Margin="0,5"/>
                    <CheckBox x:Name="LunchBox" IsChecked="{Binding AllowLunch}" Content="允許午餐" Margin="0,5"/>
                    <CheckBox x:Name="DinnerBox" IsChecked="{Binding AllowDinner}" Content="允許晚餐" Margin="0,5"/>
                    <CheckBox x:Name="DozeBox" IsChecked="{Binding AllowDoze}" Content="允許瞌睡" Margin="0,5"/>
                    <CheckBox x:Name="OverTimeBox" IsChecked="{Binding AllowOverTime}" Content="允許加班" Margin="0,5"/>
                    <CheckBox x:Name="MadBox" IsChecked="{Binding AllowMad}" Content="允許發瘋" Margin="0,5"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5" IsEnabled="False">
                    <CheckBox x:Name="LeaderBox" IsChecked="{Binding AllowLeader}" Content="允許教主" Margin="0,5"/>
                    <CheckBox x:Name="UpdateBox" IsChecked="{Binding AllowUpdate}" Content="允許更新" Margin="0,5"/>
                    <CheckBox x:Name="AdvertiseBox" IsChecked="{Binding AllowAdvertise}" Content="允許廣告" Margin="0,5"/>
                    <CheckBox x:Name="ItBox" IsChecked="{Binding AllowIt}" Content="哀踢通知" Margin="0,5"/>
                    <CheckBox x:Name="HrBox" IsChecked="{Binding AllowHr}" Content="人資通知" Margin="0,5"/>
                    <CheckBox x:Name="AdmBox" IsChecked="{Binding AllowAdm}" Content="管理通知" Margin="0,5"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2">
                <!-- 午餐時間 -->
                <GroupBox Header="午餐時間" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Label Content="開始" Width="40"/>
                        <TextBox Text="{Binding LunchStartHour}" Width="40"/>
                        <Label Content=":"/>
                        <TextBox Text="{Binding LunchStartMinute}" Width="40"/>
                        <Label Content="結束" Width="40" Margin="10,0,0,0"/>
                        <TextBox Text="{Binding LunchEndHour}" Width="40"/>
                        <Label Content=":"/>
                        <TextBox Text="{Binding LunchEndMinute}" Width="40"/>
                    </StackPanel>
                </GroupBox>

                <!-- 晚餐時間 -->
                <GroupBox Header="晚餐時間" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <Label Content="開始" Width="40"/>
                        <TextBox Text="{Binding DinnerStartHour}" Width="40"/>
                        <Label Content=":"/>
                        <TextBox Text="{Binding DinnerStartMinute}" Width="40"/>
                        <Label Content="結束" Width="40" Margin="10,0,0,0"/>
                        <TextBox Text="{Binding DinnerEndHour}" Width="40"/>
                        <Label Content=":"/>
                        <TextBox Text="{Binding DinnerEndMinute}" Width="40"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="鬧鐘設定" Margin="0,10,0,0">
                    <StackPanel Margin="5">
                        <CheckBox x:Name="AlarmBox" IsChecked="{Binding AllowAlarm}" Content="啟用鬧鐘" Margin="0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Label Content="時間" Width="40"/>
                            <TextBox Text="{Binding AlarmHour}" Width="40"/>
                            <Label Content=":"/>
                            <TextBox Text="{Binding AlarmMinute}" Width="40"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- 儲存按鈕 -->
            <Button x:Name="SaveButton" Content="儲存" Grid.Row="3" Width="80" Height="30" 
                    HorizontalAlignment="Right" Margin="0,10,0,0"/>
        </Grid>
    </ScrollViewer>
</Window>