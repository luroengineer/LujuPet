<Window x:Class="LujuPet.EncodeDecodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="編碼/解碼工具" Height="170" Width="614"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Label Content= "???" Name="Label_key"/>
        </StackPanel>
        <!-- 上排：Encode -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,5">
            <TextBox x:Name="EncodeInputBox" Width="200" Margin="5"/>
            <TextBox x:Name="EncodeOutputBox" Width="200" Margin="5" IsReadOnly="True"/>
            <Button x:Name="EncodeButton" Content="Encode" Width="80" Margin="5" Click="EncodeButton_Click"/>
        </StackPanel>

        <!-- 下排：Decode -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,5">
            <TextBox x:Name="DecodeInputBox" Width="200" Margin="5"/>
            <TextBox x:Name="DecodeOutputBox" Width="200" Margin="5" IsReadOnly="True"/>
            <Button x:Name="DecodeButton" Content="Decode" Width="80" Margin="5" Click="DecodeButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
