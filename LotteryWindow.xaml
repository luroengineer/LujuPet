<Window x:Class="LujuPet.LotteryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="抽獎活動" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 標題 -->
            <RowDefinition Height="*"/>
            <!-- 圖片 -->
            <RowDefinition Height="Auto"/>
            <!-- 按鈕 -->
        </Grid.RowDefinitions>

        <!-- 標題 -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" Text="抽獎活動" 
                   FontSize="25" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,10"/>
            <Label Name="ContentText" Content="" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 抽獎圖片/動畫 -->
        <Grid>
            <Image x:Name="LotteryImage" Grid.Row="1" 
               Stretch="Uniform" 
               gif:ImageBehavior.AnimatedSource="Images/default.gif" />
        </Grid>
        <!-- 按鈕區 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button x:Name="JoinButton" Content="參加抽獎" Width="100" Margin="5" Click="JoinButton_Click"/>
            <Button x:Name="GiveUpButton" Content="放棄抽獎" Width="100" Margin="5" Click="GiveUpButton_Click"/>
        </StackPanel>
    </Grid>
</Window>